{
  "name": "pro-rata-subscription-calculator",
  "version": "1.0.0",
  "description": "A professional pro rata calculator for monthly and annual subscription calculations",
  "main": "electron/main.js",
  "homepage": "./",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "webpack serve --mode development",
    "dev:electron": "tsc electron/main.ts --outDir electron --target ES2020 --module commonjs && electron .",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:electron": "tsc electron/*.ts --outDir electron --target ES2020 --module commonjs && webpack --mode production && electron-builder",
    "build:electron:dev": "tsc electron/*.ts --outDir electron --target ES2020 --module commonjs && webpack --mode development && electron-builder --dir",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'Type checking passed'",
    "start": "npm run dev"
  },
  "keywords": [
    "calculator",
    "subscription",
    "pro-rata",
    "billing"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^6.8.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  },
  "build": {
    "appId": "com.calculator.prorata",
    "productName": "Pro Rata Calculator",
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/preload.js",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png"
    }
  }
}
